<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>charity: water | Clean water changes everything</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
  <nav>
    <div class="logo">charity: water</div>
    <div class="nav-group">
      <a class="nav-link" href="#subscribe">Get Updates</a>
      <a class="nav-btn" href="#donate">Donate Now</a>
    </div>
  </nav>

  <header class="hero">
    <div class="hero-copy">
      <p class="eyebrow">A world with clean water for all</p>
      <h1>Help communities thrive with clean water</h1>
      <p>Support clean water projects that bring health, hope, and opportunity to communities in need.</p>
      <a class="hero-btn" href="#donate">Support Clean Water</a>
    </div>
  </header>

  <% if (subscribed === '1') { %>
    <div class="alert success">Thank you! You’re now signed up for water project updates.</div>
  <% } else if (subscribed === '0') { %>
    <div class="alert error">Please enter a valid email address to receive updates.</div>
  <% } %>

  <section class="section mission-section">
    <h2>Our Purpose</h2>
    <div class="mission">
      <p>Every person deserves access to clean water. Together we fund sustainable, community-led projects that deliver safe water and transform lives.</p>
    </div>
    <div class="mission-cards">
      <article class="mission-card">
        <h3>Water for Health</h3>
        <p>Clean water reduces disease and helps children stay healthy so they can learn and grow.</p>
      </article>
      <article class="mission-card">
        <h3>Community Power</h3>
        <p>We work with local leaders so water systems are owned and maintained by the people who use them.</p>
      </article>
      <article class="mission-card">
        <h3>Transparent Giving</h3>
        <p>Your donation is directed to water projects, with full visibility into every dollar’s impact.</p>
      </article>
    </div>
  </section>

  <section class="section gallery-section">
    <h2>Field Stories</h2>
    <div class="gallery">
      <img src="/images/charitywater/charity-watch-BDZG6xjJ.jpg" alt="People around a clean water source">
      <img src="/images/charitywater/candid-DD7EBozV.jpg" alt="Children holding water containers">
      <img src="/images/charitywater/charity-navigator-Caxpe_EG.jpg" alt="Volunteers working with a community">
      <img src="/images/charitywater/bbb-BCol5qPK.jpg" alt="Fresh water infrastructure in a village">
    </div>
  </section>

  <section class="stats">
    <div class="stats-container">
      <div class="stat">
        <h3>703M</h3>
        <p>People still need access to clean drinking water.</p>
      </div>
      <div class="stat">
        <h3>100%</h3>
        <p>Donations support sustainable wells and water systems.</p>
      </div>
      <div class="stat">
        <h3>29</h3>
        <p>Years of partnering with communities worldwide.</p>
      </div>
    </div>
  </section>

  <section class="section subscribe-section" id="subscribe">
    <h2>Stay connected</h2>
    <p>Get stories, campaign updates, and volunteer opportunities delivered to your inbox.</p>
    <form class="subscribe-form" action="/subscribe" method="post">
      <input type="email" name="email" placeholder="Enter your email address" required>
      <button type="submit" class="hero-btn">Subscribe</button>
    </form>
  </section>

  <section class="cta" id="donate">
    <h2>Take action for lasting water access</h2>
    <p>Your gift builds wells, trains communities, and keeps water flowing for generations.</p>
    <a class="cta-btn" href="https://www.charitywater.org/donate" target="_blank" rel="noopener">Donate now</a>
  </section>

  <footer>
    <p>charity: water | Driven by clean water impact.</p>
  </footer>
</body>
</html>
